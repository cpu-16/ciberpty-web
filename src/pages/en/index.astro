---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import About from '../../components/About.astro';
import Skills from '../../components/Skills.astro';
import Projects from '../../components/Projects.astro';
import Timeline from '../../components/Timeline.astro';
import Certificates from '../../components/Certificates.astro';
import Contact from '../../components/Contact.astro';
import { profileEn } from '../../content/profile.en';
import { projectsEn } from '../../content/projects.en';
---

<BaseLayout profile={profileEn}>
  <Hero profile={profileEn} />
  <About profile={profileEn} />
  <Skills profile={profileEn} />
  <Projects profile={profileEn} projects={projectsEn} />
  <Timeline profile={profileEn} />
  <Certificates profile={profileEn} />
  <Contact profile={profileEn} />
</BaseLayout>
