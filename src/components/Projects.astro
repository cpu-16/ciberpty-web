---
import type { ProjectItem, ProfileContent } from '../utils/i18n';

interface Props {
  profile: ProfileContent;
  projects: ProjectItem[];
}

const { projects, profile } = Astro.props;
---

<section id="projects" class="container section" data-reveal>
  <h2>{profile.nav[1]?.label}</h2>
  <div class="project-grid">
    {projects.map((project) => (
      <article class="card project-card">
        <h3>{project.title}</h3>
        <p>{project.description}</p>
        <ul class="stack-list">
          {project.stack.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <a
          href={project.href}
          target={project.href.startsWith('http') ? '_blank' : undefined}
          rel={project.href.startsWith('http') ? 'noreferrer' : undefined}
        >
          {profile.labels.viewProject}
        </a>
      </article>
    ))}
  </div>
</section>
