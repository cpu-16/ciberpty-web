---
import { localePath, oppositeLocale, type Locale } from '../utils/i18n';

interface Props {
  locale: Locale;
  label: string;
}

const { locale, label } = Astro.props;
const nextLocale = oppositeLocale(locale);
const nextPath = localePath(nextLocale);
---

<a class="lang-toggle" href={nextPath} aria-label={label}>
  {nextLocale.toUpperCase()}
</a>
