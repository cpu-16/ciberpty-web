---
import type { ProfileContent } from '../utils/i18n';

interface Props {
  profile: ProfileContent;
}

const { profile } = Astro.props;
---

<section id="journey" class="container section timeline-grid" data-reveal>
  <article class="card method-card">
    <h2>{profile.educationTitle}</h2>
    <ul class="method-list">
      {profile.education.map((item, index) => (
        <li style={`--step:${index + 1}`}>{item}</li>
      ))}
    </ul>
  </article>

  <article class="card method-card">
    <h2>{profile.experienceTitle}</h2>
    <ul class="method-list">
      {profile.experience.map((item, index) => (
        <li style={`--step:${index + 1}`}>{item}</li>
      ))}
    </ul>
  </article>
</section>
